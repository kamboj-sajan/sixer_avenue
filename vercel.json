{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frotend/build",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "frotend/build/static/$1"
    },
    {
      "src": "/(.*\\..*)",
      "dest": "frotend/build/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frotend/build/index.html"
    }
  ]
}